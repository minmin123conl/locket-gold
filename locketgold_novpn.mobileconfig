<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PayloadContent</key>
    <array>

        <!-- ① Install custom CA cert so iOS trusts our fake RC server TLS -->
        <dict>
            <key>PayloadCertificateFileName</key>
            <string>LocketGold-CA.crt</string>
            <key>PayloadContent</key>
            <data></data>
            <key>PayloadDescription</key>
            <string>LocketGold Root CA</string>
            <key>PayloadDisplayName</key>
            <string>LocketGold-CA</string>
            <key>PayloadIdentifier</key>
            <string>com.locketgold.ca.cert</string>
            <key>PayloadType</key>
            <string>com.apple.security.root</string>
            <key>PayloadUUID</key>
            <string>EBD8390A-24B6-431E-B048-17224CD02090</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
        </dict>

        <!-- ② DNS over TLS — point to NextDNS profile that rewrites api.revenuecat.com -->
        <!-- User must add ONE rewrite rule in NextDNS dashboard (instructions below) -->
        <dict>
            <key>DNSSettings</key>
            <dict>
                <key>DNSProtocol</key>
                <string>TLS</string>
                <key>ServerAddresses</key>
                <array>
                    <!-- Replace with YOUR NextDNS ID addresses -->
                    <string>45.90.28.0</string>
                    <string>45.90.30.0</string>
                </array>
                <key>ServerName</key>
                <!-- Replace YOUR_NEXTDNS_ID with your actual NextDNS profile ID -->
                <string>YOUR_NEXTDNS_ID.dns.nextdns.io</string>
            </dict>
            <key>PayloadDescription</key>
            <string>DNS rewrite for api.revenuecat.com</string>
            <key>PayloadDisplayName</key>
            <string>LocketGold DNS</string>
            <key>PayloadIdentifier</key>
            <string>com.locketgold.dns</string>
            <key>PayloadType</key>
            <string>com.apple.dnsSettings.managed</string>
            <key>PayloadUUID</key>
            <string>EF397645-A665-4DC1-A426-C805CD4FC19E</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
        </dict>

    </array>
    <key>PayloadDescription</key>
    <string>LocketGold — No VPN required. Installs CA cert + DNS rewrite.</string>
    <key>PayloadDisplayName</key>
    <string>LocketGold No-VPN</string>
    <key>PayloadIdentifier</key>
    <string>com.locketgold.novpn</string>
    <key>PayloadRemovalDisallowed</key>
    <false/>
    <key>PayloadType</key>
    <string>Configuration</string>
    <key>PayloadUUID</key>
    <string>67BB6BED-D367-4B51-8BB9-050A3A08326C</string>
    <key>PayloadVersion</key>
    <integer>1</integer>
</dict>
</plist>